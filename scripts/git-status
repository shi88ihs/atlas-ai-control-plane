#!/usr/bin/env bash
# Git Status command for Control Plane

REPO_DIR="/opt/data/home/control-plane"

cd "$REPO_DIR" || exit 1

echo "Repository          : $(git rev-parse --show-toplevel 2>/dev/null || echo 'Not a git repository')"
echo "Current branch      : $(git branch --show-current 2>/dev/null || echo 'No branch')"
echo "Last commit         : $(git log -1 --format="%h - %s" 2>/dev/null || echo 'No commits')"
echo "Remote status       : $(git remote -v | head -n 1 | awk '{print $2}' || echo 'No remote')"
echo "Working tree status :"
git status --short
